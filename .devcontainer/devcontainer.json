{
  "name": "SALT Dev Tools",
  "build": {
    "dockerfile": "../Dockerfile.devtools",
    "context": ".."
  },
  "remoteUser": "salt",
  "workspaceMount": "source=${localWorkspaceFolder},target=/home/salt/src,type=bind",
  "workspaceFolder": "/home/salt/src",
  "remoteEnv": {
    "ANTHROPIC_API_KEY": "${localEnv:ANTHROPIC_API_KEY}",
    "GH_TOKEN": "${localEnv:GH_TOKEN}",
    "GIT_AUTHOR_NAME": "${localEnv:GIT_AUTHOR_NAME}",
    "GIT_AUTHOR_EMAIL": "${localEnv:GIT_AUTHOR_EMAIL}"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "github.copilot",
        "github.copilot-chat"
      ]
    }
  },
  "runArgs": [
    "--tmpfs=/dev/shm:rw,nosuid,nodev,exec",
    "--privileged"
  ]
}
